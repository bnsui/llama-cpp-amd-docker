FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# 安装 Vulkan 运行核心库和驱动 (无需开发包)
RUN apt-get update && apt-get install -y \
    libvulkan1 \
    vulkan-tools \
    mesa-vulkan-drivers \
    curl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

ARG DOWNLOAD_URL
WORKDIR /app

# 下载官方预编译二进制并解压
RUN curl -L ${DOWNLOAD_URL} -o llama.tar.gz && \
    tar -xzvf llama.tar.gz && \
    rm llama.tar.gz && \
    chmod +x *

ENTRYPOINT ["./llama-server"]
