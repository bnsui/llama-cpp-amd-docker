FROM ubuntu:22.04
ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    libvulkan1 vulkan-tools mesa-vulkan-drivers curl ca-certificates libgomp1 && \
    rm -rf /var/lib/apt/lists/*

ARG DOWNLOAD_URL
WORKDIR /app

RUN curl -L ${DOWNLOAD_URL} -o llama.tar.gz && \
    tar -xzvf llama.tar.gz --strip-components=1 && \
    rm llama.tar.gz && \
    chmod +x llama-server

ENV LD_LIBRARY_PATH=/app:$LD_LIBRARY_PATH
ENTRYPOINT ["./llama-server"]
