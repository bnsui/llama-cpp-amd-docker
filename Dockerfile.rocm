FROM ubuntu:22.04

# 安装运行所需的依赖环境
RUN apt-get update && apt-get install -y \
    libhipblas-dev \
    rocblas-dev \
    ca-certificates \
    curl \
    && rm -rf /var/lib/apt/lists/*

ARG DOWNLOAD_URL
WORKDIR /app

# 下载官方二进制包并解压
RUN curl -L ${DOWNLOAD_URL} -o llama.tar.gz && \
    tar -xzvf llama.tar.gz && \
    rm llama.tar.gz && \
    chmod +x *

ENTRYPOINT ["./llama-server"]
